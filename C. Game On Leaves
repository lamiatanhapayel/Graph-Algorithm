#include<bits/stdc++.h>

using namespace std;

void solve(){
    int n,m;
    cin >> n >> m;

    vector<int> a(n+1,0);

    for(int i=0;i<n-1;i++){
        int u,v;
        cin >> u >> v;
        a[u]++;
        a[v]++;
    }

    if(a[m] <= 1 || n%2 == 0) cout << "Ayush\n";
    else cout << "Ashish\n";
}

int main()
{
    int t;
    cin >> t;
    while(t--) solve();
    return 0;
} 
