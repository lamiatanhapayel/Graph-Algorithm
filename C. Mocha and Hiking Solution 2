#include<bits/stdc++.h>

using namespace std;

void solve(){
    int n;
    cin >> n;

    vector<int> v(n+1);
    for(int i=1;i<=n;i++){
        cin >> v[i];
    }

    //Case 1 : 
    if(v[1] == 1){
        cout << n+1 << " ";

        for(int i = 1;i<=n;i++){
            cout << i << " ";
        }
        cout << endl;
        return;
    }

    //Case 2 :
    if(v[n] == 0){
        for(int i=1;i<=n;i++){
            cout << i << " ";
        }

        cout << n+1 << endl;
        return;
    }

    // Case 3:
    for(int i=1;i<n;i++){

        if(v[i] == 0 && v[i+1] == 1){
            for(int j=1;j<=i;j++){
                cout << j << " ";
            }

            cout << n+1 << " ";
            
            for(int j=i+1;j<=n;j++){
                cout << j << " ";
            }
            cout << endl;
            return;
        }
    }

    cout << -1 << endl;
}

int main(){
    int t;
    cin >> t;
    while(t--){
        solve();
    }
    return 0;
}
